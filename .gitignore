# -------------------------------------------------------------------------
# PROJECT STRUCTURE & DATA EXCLUSION
# -------------------------------------------------------------------------
# Exclude intermediate/processed data from version control to ensure reproducibility
# and to keep the repository clean. All necessary data can be regenerated from raw sources.

# Exclude all intermediate data
/data/02_intermediate/
/data/03_primary/
/data/04_feature/
/data/05_model_input/

# Exclude any temporary or processed files in other locations
/temp/

# -------------------------------------------------------------------------
# MODEL & ARTIFACT EXCLUSION
# -------------------------------------------------------------------------
# Exclude trained models and artifacts that should be generated by running the pipeline

# Exclude saved models
/data/06_models/
/data/07_model_output/

# Exclude evaluation reports and metrics
/data/08_reporting/
/data/09_intermediate_reports/
